# ───────── Core ─────────
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
SITE_URL=http://localhost:3000

# ───────── Database ─────────
DATABASE_URL=postgresql://rc:rc_dev_password@localhost:5432/resource_centre?schema=public

# ───────── Redis / queues ─────────
REDIS_URL=redis://localhost:6379
ALERTS_INTERVAL_MS=900000

# ───────── Search ─────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=rc_dev_meili_key

# ───────── Auth (Phase 5) ─────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ───────── Email (Phase 7) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Resource Centre <no-reply@resourcecentre.co.ke>"

# ───────── SMS / WhatsApp (Phase 7) ─────────
SMS_API_KEY=
SMS_USERNAME=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ───────── M-Pesa Daraja (Phase 10) ─────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ───────── Monetization ─────────
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ───────── Tip us (display-only M-Pesa) ─────────
# Shown on /tip and the "Tip us" prompt. Set Till OR Paybill (or both).
# Must be NEXT_PUBLIC_* so the Next.js web app can read them.
NEXT_PUBLIC_TIP_TILL=
NEXT_PUBLIC_TIP_PAYBILL=
NEXT_PUBLIC_TIP_PAYBILL_ACCOUNT=TIP
NEXT_PUBLIC_TIP_NAME=Resource Centre

# ───────── Admin / maintenance ─────────
ADMIN_EMAILS=admin@resourcecentre.co.ke
TRUST_RECOMPUTE_MS=86400000

# ───────── Price ingestion (Phase 9) ─────────
INGEST_INTERVAL_MS=21600000
INGEST_SIMULATION=true
INGEST_FEED_URL=
