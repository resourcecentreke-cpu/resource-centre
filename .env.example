# ───────── Core ─────────
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_BASE_URL=http://localhost:4000
SITE_URL=http://localhost:3000

# ───────── Database ─────────
DATABASE_URL=postgresql://rc:rc_dev_password@localhost:5432/resource_centre?schema=public

# ───────── Redis / queues ─────────
REDIS_URL=redis://localhost:6379
ALERTS_INTERVAL_MS=900000

# ───────── Search ─────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=rc_dev_meili_key

# ───────── Auth (Phase 5) ─────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ───────── Email (Phase 7) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Resource Centre <no-reply@resourcecentre.co.ke>"

# ───────── SMS / WhatsApp (Phase 7) ─────────
SMS_API_KEY=
SMS_USERNAME=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ───────── M-Pesa Daraja (Phase 10) ─────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ───────── Tip via IntaSend (aggregator → settles to your bank) ─────────
# Preferred path for "Tip us" STK push when you don't own an M-Pesa shortcode.
# Get keys at https://payment.intasend.com. Set INTASEND_ENV=test for sandbox.
INTASEND_ENV=live
INTASEND_PUBLISHABLE_KEY=
INTASEND_SECRET_KEY=
TIP_EMAIL=tips@resourcecentre.co.ke

# ───────── Monetization ─────────
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Web app (NEXT_PUBLIC_* so the browser can read them). Loader + ads.txt use the client id.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-7697180631053911
# Optional: a display ad-unit slot id from your AdSense account for in-content <AdSlot/> units.
NEXT_PUBLIC_ADSENSE_SLOT=

# ───────── Extra ad networks (pay-per-click/impression, good KE rates) ─────────
# Adsterra (adsterra.com — quick approval, strong Kenyan-traffic payouts):
# create a Banner ad unit, then paste its key + invoke.js URL. Components stay
# invisible until both are set.
NEXT_PUBLIC_ADSTERRA_KEY=
NEXT_PUBLIC_ADSTERRA_SRC=
# Monetag (monetag.com — $5 min payout): paste the tag snippet's src + data-zone.
NEXT_PUBLIC_MONETAG_SRC=
NEXT_PUBLIC_MONETAG_ZONE=

# ───────── Affiliate links (outbound /api/go/:offerId redirects) ─────────
# Jumia KOL (kol.jumia.com/register — commission on every referred sale,
# payout from KSh 3,500): once approved, put your tracking params in
# AFFILIATE_QUERY_JSON for the jumia seller slug.
# Admitad (site already carries the verify-admitad tag): create a deeplink for
# an advertiser and put it in AFFILIATE_WRAPPER_JSON, e.g.
#   {"kilimall":"https://ad.admitad.com/g/YOUR_CAMPAIGN/?ulp={url}"}
# Per-seller affiliate codes, keyed by seller slug. Fill as your affiliate
# accounts (Jumia KOL, Kilimall, etc.) are approved — no code changes needed.
# Query params appended to the seller's product URL:
#   {"jumia-kenya":"aff_id=YOUR_AFF_ID","kilimall":"tag=YOUR_TAG"}
AFFILIATE_QUERY_JSON=
# For networks that wrap the destination URL ({url} = encoded target):
#   {"jumia-kenya":"https://track.network.com/click?pid=YOUR_PID&url={url}"}
AFFILIATE_WRAPPER_JSON=

# ───────── Concierge checkout (we buy for the customer) ─────────
# Service fee added on top of the store price: pct of price, clamped to [min,max] KES.
ORDER_FEE_PCT=3
ORDER_FEE_MIN=200
ORDER_FEE_MAX=5000
# Shared secret configured in the IntaSend dashboard webhook (POST /api/payments/intasend-webhook).
# Confirms payments automatically so orders flip to PAID without manual checks.
INTASEND_WEBHOOK_CHALLENGE=

# ───────── Tip us (M-Pesa Paybill → bank account) ─────────
# Shown on /tip. Defaults to DTB Paybill 516600 + bank account 0281877001.
# Must be NEXT_PUBLIC_* so the Next.js web app can read them (set in apps/web/.env on the server).
NEXT_PUBLIC_TIP_TILL=
NEXT_PUBLIC_TIP_PAYBILL=516600
NEXT_PUBLIC_TIP_PAYBILL_ACCOUNT=0281877001
NEXT_PUBLIC_TIP_BANK=Diamond Trust Bank (DTB)
NEXT_PUBLIC_TIP_NAME=Resource Centre

# ───────── Admin / maintenance ─────────
ADMIN_EMAILS=admin@resourcecentre.co.ke
# Shared key for the no-code /admin page (add products + upload photos). Pick a long random string.
MANAGE_KEY=
# Where uploaded product photos are written (served by the web app at /products/<file>).
# Defaults to apps/web/public/products relative to the API process. Override if needed.
PRODUCTS_IMAGE_DIR=
TRUST_RECOMPUTE_MS=86400000

# ───────── Price ingestion (Phase 9) ─────────
INGEST_INTERVAL_MS=21600000
INGEST_SIMULATION=true
INGEST_FEED_URL=
