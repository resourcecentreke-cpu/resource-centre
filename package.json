{
  "name": "resource-centre",
  "version": "0.1.0",
  "private": true,
  "description": "Resource Centre — Kenya electronics price-comparison platform (monorepo)",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @rc/db generate",
    "db:migrate": "pnpm --filter @rc/db migrate",
    "db:seed": "pnpm --filter @rc/db seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "prettier": "^3.3.3"
  }
}
